# OpenRouter API Key (required)
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Groq API Key (recommended for OCR fallback and higher stability)
GROQ_API_KEY=your_groq_api_key_here

# Model Configuration (optional - defaults provided)
NLU_MODEL=openrouter/auto
NLU_FALLBACK_MODELS=meta-llama/llama-3.1-8b-instruct,openai/gpt-4o-mini
PLANNER_MODEL=openrouter/auto

# OCR runtime controls (optional)
# Prefer Groq first for OCR, then OpenRouter fallback.
OCR_PROVIDER_ORDER=groq,openrouter
OCR_GROQ_VISION_MODELS=meta-llama/llama-4-scout-17b-16e-instruct
OCR_VISION_MODELS=google/gemma-3-27b-it:free,meta-llama/llama-3.2-11b-vision-instruct:free
OCR_VISION_MAX_429_RETRIES=2

# Langfuse (Observability - MANDATORY)
LANGFUSE_PUBLIC_KEY=pk-xxx
LANGFUSE_SECRET_KEY=sk-xxx
LANGFUSE_HOST=https://cloud.langfuse.com

# Pinecone (Cloud Vector DB - lightweight alternative to ChromaDB)
PINECONE_API_KEY=pcsk_xxx
PINECONE_INDEX=mediloon

# OpenAI (for embeddings - can use same key as OpenRouter if it supports embeddings)
OPENAI_API_KEY=sk-xxx

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Order limits (backend-enforced for text + voice + direct UI add)
MAX_ORDER_TOTAL_UNITS=30
MAX_ORDER_SUBTOTAL_EUR=500
MAX_ORDER_LINE_QTY=10

# RX enforcement + bypass
RX_ENFORCEMENT_ENABLED=true
RX_BYPASS_ENABLED=false
RX_BYPASS_TOKEN=
RX_BYPASS_PHRASE=override rx
RX_REQUIRED_KEYWORDS=amoxicillin,azithromycin,ciprofloxacin,doxycycline,metformin,ramipril,atorvastatin,levothyroxine
