{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/test",
      "destination": "/api/test.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "runtime": "@vercel/python@4.6.0",
      "maxDuration": 60,
      "excludeFiles": "{tests/**,backend/tests/**,backend/venv/**,backend/__pycache__/**,backend/test_*.py,**/*.test.py,uploads/**,backend/uploads/**,data/chroma_db/**,frontend/**,node_modules/**}"
    }
  }
}